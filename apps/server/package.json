{
  "name": "@repo/server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/apps/server/src/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/server/src/index.js",
    "serve": "NODE_ENV=production HOST=${HOST:-0.0.0.0} PORT=${PORT:-3000} node dist/apps/server/src/index.js",
    "release": "node ../../scripts/check-node-version.cjs && npm run build --workspace @repo/shared && npm run build --workspace @repo/client && npm run build --workspace @repo/server && npm run serve --workspace @repo/server",
    "db": "docker-compose up -d",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.3.0",
    "@repo/shared": "*",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "knex": "^3.2.6",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
